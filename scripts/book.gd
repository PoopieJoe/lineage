extends Node2D

@onready var leftPage: Page = $LeftPage
@onready var rightPage: Page = $RightPage
@onready var leftPageNr: int = 1
@onready var storyteller = $Storyteller

var currentpage: int = 0
var _event_section: EventNode
var pages: Array[PageElement]
var settings: Dictionary
    
func next_page() -> void:
    if currentpage < pages.size() - 2:
        load_page(currentpage + 2)
    
func prev_page() -> void:
    if currentpage > 0:
        load_page(currentpage - 2)
    
func reload_page() -> void:
    load_page(currentpage)

func load_page(page: int) -> void:
    currentpage = page
    if page < pages.size():
        leftPage.clear()
        leftPage.loadContent(pages[page], page + 1)
    if page + 1 < pages.size():
        rightPage.clear()
        rightPage.loadContent(pages[page + 1], page + 2)
    
func extend_page(page: PageElement, elements: Array[PageElement]) -> PageElement:
    var page_full = false
    while not page_full:
        var e: PageElement = elements.pop_front()
        if e == null:
            break
        var page_size = page.get_rect().size
        var c_size = e.get_rect().size
        assert(c_size.y < leftPage.size.y)
        
        if page_size.y + c_size.y > leftPage.size.y:
            page_full = true
            elements.push_front(e)
        else:
            page.add_child(e)
            e.position = Vector2(0, page_size.y)
            page.set_size(Vector2(leftPage.size.x, page_size.y + c_size.y))
    return page

func make_page(elements: Array[PageElement]) -> PageElement:
    var new_page = PageElement.new()
    return extend_page(new_page, elements)

func make_page_elements(_node: EventNode) -> Array[PageElement]:
    return EventUIBuilder.make_UIElements(
        _node,
        click_choice,
        settings["text_rendering"]
    )

func add_elements(elements: Array[PageElement]) -> void:        
    if pages.size() == 0:
        var first_page = make_page(elements)
        pages.append(first_page)
    else:
        extend_page(pages[-1], elements)
        
    while elements.size() > 0:
        var new_page = make_page(elements)
        pages.append(new_page)
    reload_page()
  
func click_choice(element: PageElement) -> void:
    if element is ChoiceButton2D:
        var node = element.get_evt_node()
        storyteller.click(node)
        _event_section = storyteller.get_current_event() \
            .build_next_section(\
                storyteller.get_world_state() \
            )

        add_elements(make_page_elements(_event_section))

func _ready() -> void:
    if $DebugLog/VBoxContainer/Feed:
        Logger.set_output($DebugLog/VBoxContainer/Feed)

    settings = YAML.parse_file("res://settings.yaml")

    # Generated by game logic or loaded directly from file?
    var event = storyteller.get_current_event()
    _event_section = event.build_sections_start(\
            storyteller.get_world_state() \
        )
    Logger.log("Loaded event '%s'" % event.get_identifier())
    
    add_elements(make_page_elements(_event_section))
    
    load_page(0)

func _on_left_page_button_button_up() -> void:
    prev_page()

func _on_right_page_button_button_up() -> void:
    next_page()
